# Slack tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# GitLab
GITLAB_TOKEN=glpat-your-token
GITLAB_URL=https://gitlab.example.com
# Path to CA bundle for self-signed/internal certificates (optional)
# REQUESTS_CA_BUNDLE=./my_ca.crt

# Storage
DATABASE_PATH=/data/mr-notify.db

# Logging
LOG_LEVEL=INFO

# Defaults
DEFAULT_SCHEDULE=0 9 * * 1-5
DEFAULT_POLL_INTERVAL=*/5 * * * *
DEFAULT_MODE=digest

# Bot admins (comma-separated Slack user IDs, optional)
# BOT_ADMINS=U0XXXXXX,U0YYYYYY
